// ============================================
// SCOPE ERROR TEST FILE
// This file contains examples of all scope errors
// ============================================

// --- ERROR 1: EnumRedefinition ---
// Declaring the same enum twice
qism Color {
    Red,
    Green,
    Blue
};

qism Color {  // ERROR: Enum redefinition
    Yellow,
    Purple
};

// --- ERROR 2: EnumVariantRedefinition ---
// Same value name used twice in one enum
qism Status {
    Active,
    Inactive,
    Active  // ERROR: Enum variant redefinition
};

// --- ERROR 3: InvalidStorageClassUsage ---
// Enum declared in non-global scope (inside function)
yaar {
    qism LocalEnum {  // ERROR: Invalid storage class usage (enums must be global)
        Value1,
        Value2
    };
}

// --- ERROR 4: ConflictingDeclaration ---
// Variable name conflicts with enum name
qism Size {
    Small,
    Large
};

number Size = 10;  // ERROR: Conflicting declaration (Size is already an enum)

// --- ERROR 5: ConflictingDeclaration (enum value conflict) ---
// Variable name conflicts with enum value
number Red = 5;  // ERROR: Conflicting declaration (Red is an enum value from Color)

// --- ERROR 6: VariableRedefinition ---
// Variable declared twice in same scope
number testVar = 10;
number testVar = 20;  // ERROR: Variable redefinition

// --- ERROR 7: FunctionPrototypeRedefinition ---
// Same function prototype declared multiple times
khaali helper(number x);
khaali helper(number x);  // ERROR: Function prototype redefinition

// --- ERROR 8: ConflictingFunctionDefinition ---
// Function defined with different signature than prototype
khaali process(number a);

khaali process(float a) {  // ERROR: Conflicting function definition (different parameter type)
    bolo(a);
}

// --- ERROR 9: ConflictingFunctionDefinition (return type) ---
// Function with same name but different return type
number calculate(number x) {
    wapsi x * 2;
}

float calculate(number x) {  // ERROR: Conflicting function definition (different return type)
    wapsi x * 2.5;
}

// --- ERROR 10: ParameterRedefinition ---
// Same parameter name used twice in function
number duplicate(number x, float x) {  // ERROR: Parameter redefinition
    wapsi x;
}

// --- ERROR 11: UndeclaredVariableAccessed ---
// Using variable that was never declared
number useUndeclared() {
    wapsi unknownVar + 5;  // ERROR: Undeclared variable accessed
}

// --- ERROR 12: UndefinedFunctionCalled ---
// Calling function that doesn't exist
yaar {
    number result = nonExistentFunc(10);  // ERROR: Undefined function called
}

// --- ERROR 13: InvalidForwardReference ---
// Using variable before it's declared (but it exists later)
number earlyUser() {
    wapsi laterDeclared;  // ERROR: Invalid forward reference
}

number laterDeclared = 100;

// --- ERROR 14: InvalidForwardReference (function) ---
// Calling function before declaration (without prototype)
number caller() {
    wapsi callee();  // ERROR: Invalid forward reference
}

number callee() {
    wapsi 42;
}

// --- ERROR 15: ConflictingDeclaration (variable vs function) ---
// Variable name conflicts with function name
khaali myFunc() {
    bolo("Hello");
}

number myFunc = 5;  // ERROR: Conflicting declaration

// --- CORRECT EXAMPLES (for comparison) ---

// Correct: Function prototype followed by definition
khaali correctFunc(number x);

khaali correctFunc(number i) {
    bolo(i);
}

// Correct: Using declared variables
number validVar = 10;

number useValidVar() {
    wapsi validVar + 5;  // OK: validVar is declared
}

// Correct: Enum values can be used as variables
qism Direction {
    North,
    South,
    East,
    West
};

number useEnumValue() {
    number dir = North;  // OK: North is an enum value
    wapsi dir;
}

// Correct: Nested scopes with same variable name (shadowing is allowed)
number outer = 10;

khaali testScoping() {
    number inner = 20;
    
    agar (inner > 0) {
        number inner = 30;  // OK: Different scope, shadows outer 'inner'
        bolo(inner);
    }
}