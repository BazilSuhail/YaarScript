// ============================================
// TYPE VALID/ ERRORS FREE TEST FILE
// Clean test program - NO TYPE ERRORS
// This file demonstrates correct usage of types, operations, and control flow.
// ============================================

qism Status {
    Active,
    Inactive,
    Pending
};

// Global declarations
number globalId = 100;
float threshold = 0.75;

// Function Prototypes
number calculateArea(number width, number height);
faisla isPassing(float score);
khaali logStatus(number s);

// Implementation
number calculateArea(number width, number height) {
    number area = width * height;
    wapsi area;
}

faisla isPassing(float score) {
    agar (score >= threshold) {
        wapsi sahi;
    }
    wapsi galat;
}

khaali logStatus(number s) {
    intekhab (s) {
        agar_ho 1:
            bolo("Status is Active");
            bas_kar;
        agar_ho 2:
            bolo("Status is Inactive");
            bas_kar;
        aakhir:
            bolo("Status is Pending");
            bas_kar;
    }
    // Void function doesn't need return, or can use return;
    wapsi;
}

yaar {
    number w = 10;
    number h = 20;
    number area = calculateArea(w, h);
    
    float myScore = 0.85;
    faisla result = isPassing(myScore);
    
    agar (result) {
        bolo("Test Passed");
    } warna {
        bolo("Test Failed");
    }
    
    number current = Active;
    logStatus(current);
    
    // Testing loops with correct types
    dohrao (number i = 0; i < 5; i++) {
        bolo(i);
        agar (i == 3) {
            bas_kar; 
        }
    }
    
    number counter = 0;
    jabtak (counter < 3) {
        counter++;
    }
    
    karo {
        bolo("Looping...");
        counter--;
    } jabtak (counter > 0);
    
    // Correct arithmetic
    number sum = 10 + w;
    float ratio = 3.14 / 2.0;
    
    // Correct logic
    faisla flag = (w > 5) && (area < 500);
    faisla check = !flag;
}